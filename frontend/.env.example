# AgriLink Frontend Environment Variables

# Backend API URL
VITE_API_URL=http://localhost:5000

# For production:
# VITE_API_URL=https://agrilink-api.onrender.com

# Socket.io Server URL (usually same as API URL)
VITE_SOCKET_URL=http://localhost:5000

# FastAPI Recommendation Service
VITE_RECOMMENDER_URL=http://localhost:8001

# For production:
# VITE_RECOMMENDER_URL=https://agrilink-recommender.onrender.com
